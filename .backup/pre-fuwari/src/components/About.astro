---
---

<section class="py-24 relative" id="about">
  <div class="w-full max-w-[1200px] mx-auto px-6">
    <span class="inline-flex items-center gap-2 font-[var(--font-mono)] text-[0.8rem] font-medium text-[var(--color-accent)] uppercase tracking-[3px] mb-3 reveal before:content-[''] before:w-6 before:h-0.5 before:bg-[var(--color-accent)] before:rounded-sm">About Me</span>
    <h2 class="text-[clamp(1.8rem,4vw,2.6rem)] font-bold text-[var(--color-text-primary)] mb-4 leading-tight reveal">Building Secure Digital Futures</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-15 items-start mt-12">
      <!-- Text -->
      <div>
        <p class="text-[var(--color-text-secondary)] mb-5 text-[1.02rem] leading-relaxed reveal">
          I'm an engineering student at the <strong class="text-[var(--color-text-primary)]">École Nationale Supérieure de l'IA et Sciences
          des Données (ENSIASD)</strong> in Taroudant, pursuing a State Engineering Diploma in
          <strong class="text-[var(--color-text-primary)]">IT Security & Digital Trust</strong>.
        </p>
        <p class="text-[var(--color-text-secondary)] mb-5 text-[1.02rem] leading-relaxed reveal">
          My professional experience includes designing enterprise-grade
          <strong class="text-[var(--color-text-primary)]">DMVPN/IPSec architectures</strong> at Groupe OCP and implementing
          <strong class="text-[var(--color-text-primary)]">FortiGate firewall policies</strong> across multi-site environments.
          I'm passionate about bridging the gap between offensive security research
          and practical network defense.
        </p>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2.5 mt-7 reveal">
          {["Network Security", "Penetration Testing", "Firewall Architecture", "ISO 27001", "SIEM / Wazuh", "Full-Stack Dev", "Python", "Cisco Routing"].map((tag) => (
            <span class="px-4 py-1.5 bg-[var(--color-accent-soft)] text-[var(--color-accent)] border border-[rgba(0,229,255,0.15)] rounded-full text-[0.82rem] font-medium font-[var(--font-mono)] transition-all duration-300 hover:bg-[rgba(0,229,255,0.15)] hover:-translate-y-0.5 cursor-default">
              {tag}
            </span>
          ))}
        </div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 gap-5">
        {[
          { number: "4+", label: "Projects Completed" },
          { number: "2", label: "Professional Internships" },
          { number: "10+", label: "Technologies Mastered" },
          { number: "3", label: "Languages Spoken" },
        ].map((stat, i) => (
          <div class={`bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-7 text-center transition-all duration-300 hover:border-[var(--color-border-hover)] hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(0,229,255,0.15)] reveal reveal-delay-${i + 1}`}>
            <div class="text-3xl font-extrabold text-[var(--color-accent)] font-[var(--font-mono)] leading-none">{stat.number}</div>
            <div class="text-[0.85rem] text-[var(--color-text-muted)] mt-2">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
