<footer class="py-8 border-t border-[var(--color-border)] text-center">
  <div class="w-full max-w-[1200px] mx-auto px-6">
    <p class="text-[0.85rem] text-[var(--color-text-muted)]">
      Designed & built by <a href="/" class="text-[var(--color-accent)] no-underline hover:underline">Zouhair Guertaoui</a> ·
      <span id="footer-year"></span>
    </p>
  </div>
</footer>

<script>
  function initFooter() {
    const el = document.getElementById('footer-year');
    if (el) el.textContent = new Date().getFullYear().toString();
  }
  initFooter();
  document.addEventListener('astro:after-swap', initFooter);
</script>
