<section class="py-24 relative" id="contact">
  <div class="w-full max-w-[1200px] mx-auto px-6">
    <span class="inline-flex items-center gap-2 font-[var(--font-mono)] text-[0.8rem] font-medium text-[var(--color-accent)] uppercase tracking-[3px] mb-3 reveal before:content-[''] before:w-6 before:h-0.5 before:bg-[var(--color-accent)] before:rounded-sm">Get In Touch</span>
    <h2 class="text-[clamp(1.8rem,4vw,2.6rem)] font-bold text-[var(--color-text-primary)] mb-4 leading-tight text-center reveal">Let's Work Together</h2>

    <div class="text-center max-w-[600px] mx-auto mt-12">
      <p class="text-[var(--color-text-secondary)] mb-9 text-[1.05rem] leading-relaxed reveal">
        I'm currently looking for internship and collaboration opportunities in
        cybersecurity, network security, and secure software development.
        Whether you have a question or just want to say hello — my inbox is always open.
      </p>

      <!-- Email CTA -->
      <a href="mailto:guertaouizouhair@gmail.com"
         class="inline-flex items-center gap-2.5 px-9 py-4 bg-[var(--color-accent)] text-[var(--color-bg-primary)] rounded-lg text-base font-bold transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_30px_rgba(0,229,255,0.35)] no-underline mb-10 reveal max-sm:w-full max-sm:justify-center">
        ✉️ guertaouizouhair@gmail.com
      </a>

      <!-- Social links -->
      <div class="flex justify-center gap-4 reveal">
        <a href="https://linkedin.com/in/zouhair-guertaoui" target="_blank" rel="noopener"
           class="w-[50px] h-[50px] rounded-full bg-[var(--color-bg-card)] border border-[var(--color-border)] flex items-center justify-center text-xl text-[var(--color-text-secondary)] transition-all duration-300 hover:text-[var(--color-accent)] hover:border-[var(--color-accent)] hover:bg-[var(--color-accent-soft)] hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(0,229,255,0.15)] no-underline"
           aria-label="LinkedIn">
          in
        </a>
        <a href="https://github.com/zouhair-guertaoui" target="_blank" rel="noopener"
           class="w-[50px] h-[50px] rounded-full bg-[var(--color-bg-card)] border border-[var(--color-border)] flex items-center justify-center text-xl text-[var(--color-text-secondary)] transition-all duration-300 hover:text-[var(--color-accent)] hover:border-[var(--color-accent)] hover:bg-[var(--color-accent-soft)] hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(0,229,255,0.15)] no-underline"
           aria-label="GitHub">
          GH
        </a>
        <a href="tel:+212604906525"
           class="w-[50px] h-[50px] rounded-full bg-[var(--color-bg-card)] border border-[var(--color-border)] flex items-center justify-center text-xl text-[var(--color-text-secondary)] transition-all duration-300 hover:text-[var(--color-accent)] hover:border-[var(--color-accent)] hover:bg-[var(--color-accent-soft)] hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(0,229,255,0.15)] no-underline"
           aria-label="Phone">
          📞
        </a>
      </div>
    </div>
  </div>
</section>
